# docker-compose 数据库凭证模板
#   cp .env.example .env
#
# 一键部署脚本 deploy.sh 会自动把下面的占位符替换成随机强密码，
# 并同步到 backend/.env 的 DATABASE_URL，无需手动改。
#
# 若手动部署：把 __AUTO_GENERATE__ 换成你自己的强密码，
# 并确保与 backend/.env 的 DATABASE_URL 中密码一致。
# 注意：密码只在【首次创建数据卷】时生效，之后要改需 docker compose down -v 删卷重建。

POSTGRES_USER=kol
POSTGRES_PASSWORD=__AUTO_GENERATE__
POSTGRES_DB=kol_finder
