# 统一行尾，避免在 Windows 上提交时把 LF 转成 CRLF（关键：.sh 在 Linux 必须是 LF）
* text=auto eol=lf

# 明确强制这些为 LF（部署相关，行尾敏感）
*.sh    text eol=lf
*.py    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
.env.example text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.json  text eol=lf
*.md    text eol=lf

# 二进制文件不处理
*.jpg   binary
*.png   binary
*.zip   binary
*.ico   binary
