# ============================================================
# KOL Finder 后端配置模板（已预设可用值，cp 为 .env 即可直接运行）
#   cp .env.example .env
# 含敏感凭证：.env 切勿提交 git（已在 .gitignore 忽略）
# 修改后需重启后端：python run.py
# ============================================================


# ------------------------------------------------------------
# 一、数据源（金山在线文档）—— 可留空，部署后在网页后台「设置」里填
# ------------------------------------------------------------
# Webhook 链接：决定从“哪个”在线文档同步。后台设置里填即可（优先级更高）。
KDOCS_WEBHOOK_URL=

# 脚本令牌 Token：访问该文档的密钥。后台设置里填即可。
KDOCS_TOKEN=

# 自动同步间隔（秒）。300 = 5 分钟。也可在网页后台用下拉选择。
SYNC_INTERVAL_SECONDS=300


# ------------------------------------------------------------
# 二、后台管理员账号
# ------------------------------------------------------------
# 登录用户名固定为：admin
#
#   留空 ADMIN_INIT_PASSWORD（当前）：全新数据库首次创建用内置默认密码
#   admin / admin123，且【首次登录强制修改密码】。
#
#   若想自定义初始密码，在 = 后填即可（设了就不强制改密，请填强密码）。
# 说明：仅对“数据库里还没有管理员”时的首次创建生效；账号已存在则不会被重置。
#       改密：后台“修改密码”或 python reset_password.py 新密码
ADMIN_INIT_PASSWORD=


# ------------------------------------------------------------
# 三、登录令牌密钥（JWT 签名，已预设强随机串）
# ------------------------------------------------------------
AUTH_SECRET=08948b4ffadcff1de3ee2b4581041572666723d5271708a2129cefdbe2d81017


# ------------------------------------------------------------
# 四、运行环境与数据库
# ------------------------------------------------------------
# production：严格模式，缺 DATABASE_URL / AUTH_SECRET 会拒绝启动。
APP_ENV=production

# 数据库连接串。密码已与根目录 .env 的 POSTGRES_PASSWORD 保持一致。
DATABASE_URL=postgresql+psycopg://kol:MxjcL5QCEd4f15FP8iniiSz0@127.0.0.1:5432/kol_finder


# ------------------------------------------------------------
# 五、CORS 与日志
# ------------------------------------------------------------
# 允许访问的前端来源。部署到服务器后改成实际地址，例如 http://服务器IP
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
